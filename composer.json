{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "holizuki/holizuki",
    "type": "project",
    "description": "Holizuki, a Laravel and Inertia React application.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "google/analytics-admin": "^0.33.0",
        "google/analytics-data": "^0.24.0",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/chisel": "^0.1.0",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.17",
        "laravel/passkeys": "^0.2.0",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.14",
        "league/commonmark": "^2.8"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "driftingly/rector-laravel": "^2.5",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "laravel/telescope": "^5.20",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-browser": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.5",
        "shipmonk/composer-dependency-analyser": "^1.8",
        "spaze/phpstan-disallowed-calls": "^4.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "Composer\\Config::disableProcessTimeout",
            "DEVBOX_USE_VERSION=0.17.5 devbox run setup"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan dev"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@quality",
            "@test",
            "npm run check",
            "npm run build"
        ],
        "types:check": [
            "phpstan analyse --memory-limit=1G"
        ],
        "rector": [
            "rector process"
        ],
        "rector:check": [
            "rector process --dry-run"
        ],
        "dependencies:check": [
            "composer-dependency-analyser"
        ],
        "type-coverage:check": [
            "@php -d memory_limit=1G vendor/bin/pest --type-coverage --min=100"
        ],
        "security:check": [
            "composer audit --locked --abandoned=fail"
        ],
        "quality": [
            "@lint:check",
            "@types:check",
            "@rector:check",
            "@dependencies:check",
            "@type-coverage:check"
        ],
        "test": [
            "@putenv APP_ENV=testing",
            "@putenv DB_CONNECTION=sqlite",
            "@putenv DB_DATABASE=:memory:",
            "@putenv DB_URL=",
            "@php artisan config:clear --ansi",
            "@php artisan test --compact"
        ],
        "test:coverage": [
            "@putenv APP_ENV=testing",
            "@putenv DB_CONNECTION=sqlite",
            "@putenv DB_DATABASE=:memory:",
            "@putenv DB_URL=",
            "@putenv XDEBUG_MODE=coverage",
            "@php -d memory_limit=1G vendor/bin/pest --coverage --min=90"
        ],
        "test:browser": [
            "@putenv APP_ENV=testing",
            "@putenv DB_CONNECTION=sqlite",
            "@putenv DB_DATABASE=:memory:",
            "@putenv DB_URL=",
            "pest tests/Browser"
        ],
        "test:mutation": [
            "@putenv APP_ENV=testing",
            "@putenv DB_CONNECTION=sqlite",
            "@putenv DB_DATABASE=:memory:",
            "@putenv DB_URL=",
            "@putenv XDEBUG_MODE=coverage",
            "@php -d memory_limit=1G vendor/bin/pest --mutate --everything --parallel --min=30"
        ],
        "ide-helper": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ],
            "installer": {
                "post-create-project": []
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "abandoned": "fail"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
