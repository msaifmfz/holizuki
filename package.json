{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "npm@11.16.0",
    "engines": {
        "node": ">=24 <25",
        "npm": ">=11 <12"
    },
    "scripts": {
        "browser:install": "playwright install chromium",
        "browser:install:ci": "playwright install --with-deps chromium",
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "check": "npm run format:check && npm run lint:check && npm run types:check && npm run dead-code && npm run test",
        "dead-code": "knip",
        "dev": "vite",
        "format": "prettier --write resources/ .github/ package.json devbox.json tsconfig.json eslint.config.js vite.config.ts vitest.config.ts knip.json lefthook.yml",
        "format:check": "prettier --check resources/ .github/ package.json devbox.json tsconfig.json eslint.config.js vite.config.ts vitest.config.ts knip.json lefthook.yml",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "prepare": "lefthook install",
        "security:check": "npm audit --audit-level=moderate",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "types:check": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@inertiajs/vite": "^3.0.0",
        "@laravel/vite-plugin-wayfinder": "^0.1.3",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@tailwindcss/vite": "^4.1.11",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.13.3",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.2.0",
        "@vitest/coverage-v8": "^4.1.10",
        "babel-plugin-react-compiler": "^1.0.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.3",
        "eslint-plugin-react-hooks": "^7.0.0",
        "globals": "^15.14.0",
        "jsdom": "^29.1.1",
        "knip": "^6.25.0",
        "laravel-vite-plugin": "^3.0.0",
        "lefthook": "^2.1.10",
        "playwright": "^1.61.1",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.23.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@fontsource/instrument-sans": "5.2.8",
        "@inertiajs/core": "3.6.1",
        "@inertiajs/react": "^3.0.0",
        "@laravel/passkeys": "^0.2.0",
        "@radix-ui/react-avatar": "^1.1.3",
        "@radix-ui/react-checkbox": "^1.1.4",
        "@radix-ui/react-collapsible": "^1.1.3",
        "@radix-ui/react-dialog": "^1.1.6",
        "@radix-ui/react-dropdown-menu": "^2.1.6",
        "@radix-ui/react-label": "^2.1.2",
        "@radix-ui/react-navigation-menu": "^1.2.5",
        "@radix-ui/react-select": "^2.1.6",
        "@radix-ui/react-separator": "^1.1.2",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-toggle": "^1.1.2",
        "@radix-ui/react-toggle-group": "^1.1.2",
        "@radix-ui/react-tooltip": "^1.1.8",
        "@tiptap/extension-code-block-lowlight": "^3.27.3",
        "@tiptap/extension-image": "^3.27.3",
        "@tiptap/pm": "^3.27.3",
        "@tiptap/react": "^3.27.3",
        "@tiptap/starter-kit": "^3.27.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "diff": "^9.0.0",
        "highlight.js": "^11.11.1",
        "input-otp": "^1.4.2",
        "lowlight": "^3.3.0",
        "lucide-react": "^0.475.0",
        "radix-ui": "^1.6.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-easy-crop": "^6.2.2",
        "sonner": "^2.0.0",
        "tailwind-merge": "^3.0.1",
        "tailwindcss": "^4.0.0",
        "tw-animate-css": "^1.4.0"
    },
    "optionalDependencies": {
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1",
        "lightningcss-win32-x64-msvc": "^1.29.1"
    }
}
