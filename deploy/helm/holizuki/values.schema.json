{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
        "environment",
        "host",
        "release",
        "image",
        "runtimeSecretName",
        "database"
    ],
    "properties": {
        "environment": {
            "type": "string",
            "enum": ["production", "staging"]
        },
        "host": {
            "type": "string",
            "minLength": 1
        },
        "release": {
            "type": "string",
            "minLength": 1
        },
        "image": {
            "type": "object",
            "required": [
                "repository",
                "digest",
                "pullPolicy",
                "pullSecrets",
                "phpVersion"
            ],
            "properties": {
                "repository": {
                    "type": "string",
                    "minLength": 1
                },
                "digest": {
                    "type": "string",
                    "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "pullPolicy": {
                    "type": "string",
                    "enum": ["Always", "IfNotPresent", "Never"]
                },
                "pullSecrets": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "phpVersion": {
                    "type": "string",
                    "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?(?:[-.][A-Za-z0-9]+)*$"
                }
            }
        },
        "runtimeSecretName": {
            "type": "string",
            "minLength": 1
        },
        "database": {
            "type": "object",
            "required": ["host", "port", "name", "username", "sslMode"],
            "properties": {
                "host": { "type": "string", "minLength": 1 },
                "port": { "type": "string", "pattern": "^[0-9]+$" },
                "name": { "type": "string", "minLength": 1 },
                "username": { "type": "string", "minLength": 1 },
                "sslMode": {
                    "type": "string",
                    "enum": [
                        "disable",
                        "allow",
                        "prefer",
                        "require",
                        "verify-ca",
                        "verify-full"
                    ]
                }
            }
        }
    }
}
