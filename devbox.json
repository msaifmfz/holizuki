{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.5/.schema/devbox.schema.json",
    "packages": [
        "php@8.5.7",
        "php85Extensions.xdebug@3.5.3",
        "github:NixOS/nixpkgs/0bb7ec54c8483066ec9d7720e780a5caa71f8612#nodejs_24",
        "postgresql_18@18.3",
        "sqlite@3.51.2"
    ],
    "env": {
        "PGPORT": "54320",
        "TZ": "UTC",
        "XDEBUG_MODE": "off"
    },
    "shell": {
        "init_hook": [
            "if [ \"${CI:-false}\" != true ] && [ ! -f .env ]; then echo 'Local environment is not initialized; run: devbox run setup' >&2; fi"
        ],
        "scripts": {
            "setup": "bash devbox.d/setup.sh",
            "dev": "bash devbox.d/dev.sh",
            "doctor": "bash devbox.d/doctor.sh",
            "check": "composer ci:check",
            "test": "composer test",
            "browser:install": "if [ \"$(uname -s)\" = Linux ]; then npm run browser:install:ci; else npm run browser:install; fi",
            "test:browser": ["npm run build", "composer test:browser"],
            "services:stop": "devbox services stop"
        }
    }
}
